# API URL
NEXT_PUBLIC_API_URL=http://localhost:3001

# WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# Yellowstone gRPC (Pulse / new pairs). Corvus Labs trial is IP-whitelisted, so leave GRPC_TOKEN empty.
# Providers: Corvus Labs http://tyo.corvus-labs.io:10101  (docs.corvus-labs.io/corvus-rpc/grpc/limits)
GRPC_ENDPOINT=http://tyo.corvus-labs.io:10101
GRPC_TOKEN=

# Standard Solana RPC + WS (token data feed, swaps)
SOLANA_RPC_URL=http://tyo.corvus-labs.io:8899
SOLANA_WS_URL=ws://tyo.corvus-labs.io:8900
